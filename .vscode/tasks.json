            "problemMatcher": ["$gcc"],
            "detail": "Compile without running"
        },
        {
            "label": "Clean",
            "type": "shell",
            "command": "rm",
            "args": ["-rf", "bin/FluidX3D", "temp"],
            "group": "build",
            "problemMatcher": []
        }
    ]
